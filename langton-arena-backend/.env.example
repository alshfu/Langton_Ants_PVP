# ─────────────────────────────────────────────────────────────────────────────
# Langton Arena · Environment configuration
# Скопируйте этот файл в `.env` и заполните значения для локальной разработки.
# В production все секреты должны идти из Hashicorp Vault или k8s Secrets.
# ─────────────────────────────────────────────────────────────────────────────

# === General ============================================================
NODE_ENV=development                   # development | staging | production
LOG_LEVEL=info                         # trace | debug | info | warn | error | fatal
REGION=eu-west                         # eu-west | eu-east | us-east | asia

# === API Gateway ========================================================
API_PORT=3000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:5173  # фронт в dev-режиме

# === WebSocket Gateway ==================================================
WS_PORT=3001
WS_HOST=0.0.0.0
WS_MAX_CONNECTIONS=10000               # на один процесс
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MESSAGE_RATE_LIMIT=50               # сообщений/сек на клиента

# === Game Worker ========================================================
WORKER_MAX_MATCHES=50                  # одновременно на воркер
WORKER_TICK_RATE=10                    # TPS
WORKER_SNAPSHOT_EVERY_N_TICKS=10       # полный snapshot вместо дельты

# === Matchmaker =========================================================
MM_TICK_INTERVAL_MS=500                # как часто пытаемся составить матчи
MM_ACCEPT_DEADLINE_MS=15000            # время на accept после mm:match_found
MM_SR_WINDOW_INITIAL=50
MM_SR_WINDOW_MAX=500
MM_SR_WINDOW_EXPAND_AFTER_MS=10000

# === PostgreSQL =========================================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=langton
PG_PASSWORD=changeme
PG_DATABASE=langton_arena
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_STATEMENT_TIMEOUT_MS=5000

# === Redis ==============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=arena:

# === ClickHouse =========================================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=arena_analytics

# === Redpanda / Kafka ===================================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=langton-arena
KAFKA_GROUP_ID=analytics-consumer

# === Object storage (S3-compatible) =====================================
S3_ENDPOINT=http://localhost:9000      # MinIO в dev
S3_REGION=auto
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_REPLAYS=langton-replays
S3_BUCKET_AVATARS=langton-avatars
S3_BUCKET_HEATMAPS=langton-heatmaps

# === JWT ================================================================
JWT_PRIVATE_KEY_PATH=./infra/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./infra/keys/jwt-public.pem
JWT_ACCESS_TTL_SEC=900                 # 15 минут
JWT_REFRESH_TTL_SEC=2592000            # 30 дней
JWT_ISSUER=langton-arena
JWT_AUDIENCE=langton-arena-client

# === Rate limiting ======================================================
RATELIMIT_API_PER_IP=100               # RPS
RATELIMIT_API_PER_USER=1000            # RPS
RATELIMIT_AUTH_LOGIN_PER_IP=5          # попыток/мин

# === Telemetry ==========================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
METRICS_PORT=9090                      # Prometheus scrape

# === Security ===========================================================
ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
CAPTCHA_HCAPTCHA_SECRET=
CAPTCHA_HCAPTCHA_SITEKEY=
