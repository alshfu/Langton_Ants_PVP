{
  "name": "@langton/mvp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Stage 8 PvP MVP — single-process WebSocket game server. Временный, мигрирует в ws-gateway+game-worker в Stage 10.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
