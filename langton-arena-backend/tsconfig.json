{
  "//": "Корневой tsconfig для всего monorepo. Каждый workspace может переопределять опции в своём tsconfig.json.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@core/*":     ["core/src/*"],
      "@protocol/*": ["core/src/protocol/*"],
      "@contract/*": ["core/src/contract/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
