{
  "name": "langton-arena-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Langton Arena · Backend monorepo",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "core",
    "services/*"
  ],
  "scripts": {
    "build":     "pnpm -r build",
    "test":      "pnpm -r test",
    "lint":      "eslint . --ext .ts",
    "format":    "prettier --write .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "dev":       "./scripts/dev.sh",
    "migrate":   "./scripts/migrate.sh"
  },
  "devDependencies": {
    "@types/node":            "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser":        "^7.0.0",
    "eslint":                 "^8.56.0",
    "prettier":               "^3.2.0",
    "typescript":             "^5.3.0",
    "vitest":                 "^1.2.0"
  },
  "packageManager": "pnpm@8.15.0"
}
